      "response_limit": 400,
      "style": "自由で発散的",
      "format": "箇条書き推奨",
      "phases": [
        {
          "type": "parallel",
          "steps": [
            {
              "role": "企画",
              "action": "テーマに対する新規アイデアを3案以上提案する"
            },
            {
              "role": "分析官",
              "action": "データ観点で成立しやすい案とリスクを短く提案する"
            },
            {
              "role": "デザイナー",
              "action": "ユーザー体験の観点で刺さる案を提案する"
            },
            {
              "role": "マーケター",
              "action": "市場性と差別化の観点で案を提案する"
            }
          ]
